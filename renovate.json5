{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
  ],
  kubernetes: {
    managerFilePatterns: [
      '/\\.yaml$/',
    ],
  },
  pinDigests: true,
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/infrastructure/controllers/base/arc-.+/release\\.yaml/',
      ],
      matchStrings: [
        'chart: (?<depName>[\\w-]+)\\s+version: "(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'docker',
      registryUrlTemplate: 'https://ghcr.io',
      packageNameTemplate: 'actions/actions-runner-controller-charts/{{depName}}',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/infrastructure/k3s-upgrade-plans/plans\\.yaml/',
      ],
      matchStrings: [
        'version: (?<currentValue>v[^\\n]+)',
      ],
      depNameTemplate: 'k3s-io/k3s',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\+k3s(?<build>\\d+)$',
    },
  ],
  packageRules: [
    {
      matchPackageNames: [
        'ghcr.io/milanoid-labs/homelab-runner',
      ],
      matchUpdateTypes: [
        'digest',
      ],
      automerge: true,
    },
    {
      matchUpdateTypes: [
        'digest',
      ],
      automerge: false,
    },
    {
      matchManagers: [
        'flux',
      ],
      pinDigests: false,
    },
    {
      matchManagers: [
        'custom.regex',
      ],
      matchPackageNames: [
        'actions/actions-runner-controller-charts/**',
      ],
      pinDigests: false,
    },
    {
      matchManagers: ['custom.regex'],
      matchPackageNames: ['k3s-io/k3s'],
      pinDigests: false,
      groupName: 'k3s upgrade',
    },
    {
      matchManagers: ['kubernetes'],
      matchPackageNames: ['rancher/k3s-upgrade'],
      groupName: 'k3s upgrade',
    },
    {
      matchPackageNames: [
        'renovate/renovate',
      ],
      schedule: [
        'before 9am on monday',
      ],
      automerge: true,
    },
    {
      versioning: 'regex:^release-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(\\.(?<build>\\d+))?$',
      matchPackageNames: [
        '/^ghcr\\.io/hotio//',
      ],
    },
    {
      matchPackageNames: [
        'linuxserver/qbittorrent',
      ],
      versioning: 'loose',
    },
  ],
}
